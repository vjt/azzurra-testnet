# bahamut leaf-v4 conf — rendered from conf.leaf4.tmpl by entrypoint.sh.
# Autoconnects to ${HUB}:${HUB_PORT} over IPv4.

M:${SERVER_NAME}:*:${SERVER_DESC}:
A:${SERVER_DESC}:testnet admin:root@${SERVER_NAME}:

Y:1:90:0:512:150000
Y:3:90:0:20:4000000
Y:50:90:0:0:5000000
# autoconnect class
Y:60:90:180:1:12000000

I:*@*::*@*::1

O:*@*:${OPER_PASS_HASH}:${OPER_NICK}:OaARD:3
O:*@*:${AZZURRA_OPER_PASS_HASH}:azzurra:moOARD:3

P:*:::${LISTEN_PORT}
P:*::S:${LISTEN_SSL_PORT}

# Outbound S2S to the hub. leaf4-net has IPv6 disabled, so docker's
# embedded resolver returns hub.azzurra.chat as IPv4 only — bahamut's
# INET4 connect_server() accepts the A record and dials out fine. The
# hub's side uses bare-IP host fields (see conf.hub.tmpl) so the
# incoming connection matches via find_conf_ip() without rDNS, which
# docker bridges don't satisfy.
# Class 60 → autoconnect every connfreq seconds (180 here).
C:${HUB}:${LEAF_PASSWORD}:${HUB}:${HUB_PORT}:60
N:${HUB}:${LEAF_PASSWORD}:${HUB}::60

# Hub declaration for services/ucasts masking.
H:*::${HUB}

K:*:Do not IRC as root:root:
