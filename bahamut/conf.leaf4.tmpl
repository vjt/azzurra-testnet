# bahamut leaf-v4 conf — rendered from conf.leaf4.tmpl by entrypoint.sh.
# Autoconnects to ${HUB}:${HUB_PORT} over IPv4.

M:${SERVER_NAME}:*:${SERVER_DESC}:
A:${SERVER_DESC}:testnet admin:root@${SERVER_NAME}:

Y:1:90:0:512:150000
Y:3:90:0:20:4000000
Y:50:90:0:0:5000000
# Autoconnect class. connfreq=2s (vs upstream Azzurra's 180s) so the
# integration testnet recovers in seconds when the hub boots a moment
# before the leaf — without this the leaf retries every three minutes,
# which keeps it permanently in split-mode for the duration of a normal
# `scripts/integration.sh` run (no auto-op on JOIN, MODE rejected with
# 482 across the board, all six CP15-B6 e2e specs blocked).
Y:60:90:2:1:12000000

I:*@*::*@*::1

O:*@*:${OPER_PASS_HASH}:${OPER_NICK}:OaARD:3
O:*@*:${AZZURRA_OPER_PASS_HASH}:azzurra:moOARD:3

P:*:::${LISTEN_PORT}
P:*::S:${LISTEN_SSL_PORT}

# Outbound S2S to the hub. leaf4-net has IPv6 disabled, so docker's
# embedded resolver returns hub.azzurra.chat as IPv4 only — bahamut's
# INET4 connect_server() accepts the A record and dials out fine. The
# hub's side uses bare-IP host fields (see conf.hub.tmpl) so the
# incoming connection matches via find_conf_ip() without rDNS, which
# docker bridges don't satisfy.
# Class 60 → autoconnect every connfreq seconds (180 here).
C:${HUB}:${LEAF_PASSWORD}:${HUB}:${HUB_PORT}:60
N:${HUB}:${LEAF_PASSWORD}:${HUB}::60

# Hub declaration for services/ucasts masking.
H:*::${HUB}

# U-line for services. Without this, m_svsmode (m_services.c:493
# `if (!IsULine(sptr) || (parc < 3)) return 0;`) silently drops every
# SVSMODE arriving from services via the hub S2S link — services
# applies +r/+x/etc to its in-memory user struct, sends SVSMODE, but
# the leaf treats services as a regular peer server and refuses the
# privileged command. End-user symptom: NickServ IDENTIFY succeeds
# ("Password accepted, you are now identified") but the +r umode
# never lands on locally-connected users → /whois returns no
# RPL_WHOISREGNICK (307), no IsRegNick gate satisfaction. The hub
# already U-lines services (conf.hub.tmpl) but FLAGS_ULINE is local
# to each ircd's conf — every leaf needs its own U: line.
U:services.azzurra.chat:*:*:

K:*:Do not IRC as root:root:
