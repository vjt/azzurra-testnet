# bahamut hub conf — rendered from conf.hub.tmpl by entrypoint.sh.
# Testnet only. Do not reuse for production.

# 5th field = "primary port" (ircd.c:1060/1077). Without it, bahamut falls
# back to compile-time PORTNUM (7000) and tries to bind that; if the same
# port appears in a P: line below, bind fails → "Couldn't bind to primary
# port" → exit 1. Declaring it here (= v4 S2S port) makes ircd open it via
# the M-line path and the P: line for the same port can be dropped.
M:${SERVER_NAME}:*:${SERVER_DESC}:${LINK_PORT_V4}:
A:${SERVER_DESC}:testnet admin:root@${SERVER_NAME}:

# Classes — trimmed from doc/example.conf.
Y:1:90:0:512:150000
Y:3:90:0:20:4000000
Y:50:90:0:0:5000000
Y:60:90:180:1:12000000
Y:70:60:0:0:15000000

# Client access — unrestricted for testnet.
I:*@*::*@*::1

# Oper — password is DES-crypted by entrypoint.sh via mkpasswd.
O:*@*:${OPER_PASS_HASH}:${OPER_NICK}:OaARD:3

# Client listeners.
P:*:::${LISTEN_PORT}
P:*::S:${LISTEN_SSL_PORT}

# S2S listeners.
# v4 port is already opened via the M-line (primary port). Only v6 needs a
# P: line here.
P:*:::${LINK_PORT_V6}

# Services link (over svc-net, IPv4).
C:services.azzurra.chat:${SERVICES_PASSWORD}:services.azzurra.chat:${LINK_PORT_V4}:50
N:services.azzurra.chat:${SERVICES_PASSWORD}:services.azzurra.chat::50
U:services.azzurra.chat:*:*:

# Leaf-v4 link (over leaf4-net, IPv4).
C:leaf4.azzurra.chat:${LEAF_PASSWORD}:leaf4.azzurra.chat:${LINK_PORT_V4}:50
N:leaf4.azzurra.chat:${LEAF_PASSWORD}:leaf4.azzurra.chat::50

# Leaf-v6 link (over leaf6-net, IPv6 ULA).
C:leaf6.azzurra.chat:${LEAF_PASSWORD}:leaf6.azzurra.chat:${LINK_PORT_V6}:50
N:leaf6.azzurra.chat:${LEAF_PASSWORD}:leaf6.azzurra.chat::50

# Hub self-declaration — keeps us from accidentally acting as a leaf.
H:*::${SERVER_NAME}

# Deny root.
K:*:Do not IRC as root:root:
