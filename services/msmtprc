# /etc/msmtprc — GH #349, TESTNET ONLY. Relays ALL mail, unauthenticated
# and in cleartext, to the mailpit sink on the grappa-e2e bridge so the
# registration-wizard e2e can read the emailed AUTH code. No secrets here
# (auth off) so a 0644 root-owned file is fine — msmtp only refuses a
# config *writable by others*, not a readable one.
#
# services (as the `services` user) invokes this as:
#   /usr/sbin/sendmail -f <RETURN> -t < authnick.txt
# msmtp honors -t (recipients from To:/Cc:/Bcc:) and -f (envelope from).
# Only reached when the compose sets SVC_EMAIL=1; the standalone
# azzurra-testnet leaves email off and never invokes msmtp.

defaults
auth           off
tls            off
logfile        /tmp/msmtp.log

account        mailpit
host           mailpit
port           1025
from           noreply@azzurra.test

account default : mailpit
