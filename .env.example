# Azzurra testnet — environment knobs.
# Copy to `.env` and edit. All defaults are testnet-safe; change for your setup.

# Git refs to build from (bahamut + services). master = latest.
BAHAMUT_REF=master
SERVICES_REF=master

# S2S link passwords (used in C/N lines).
LEAF_PASSWORD=testleaf
SERVICES_PASSWORD=testlink

# Oper credentials. Plaintext in this file, hashed (crypt) into bahamut.conf
# at entrypoint time — see bahamut/entrypoint.sh.
OPER_NICK=testoper
OPER_PASS=testoperpass

# Server link ports on hub (internal — not exposed to host).
LINK_PORT_V4=7000
LINK_PORT_V6=7001
